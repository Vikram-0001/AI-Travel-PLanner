# ── LLM ──────────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-70b-8192         # or mixtral-8x7b-32768

# ── Amadeus (Flights / Hotels / Attractions) ──────────────────────────────────
AMADEUS_CLIENT_ID=your_amadeus_client_id_here
AMADEUS_CLIENT_SECRET=your_amadeus_client_secret_here
AMADEUS_BASE_URL=https://test.api.amadeus.com   # change to prod URL for live data

# ── OpenWeatherMap ────────────────────────────────────────────────────────────
OPENWEATHER_API_KEY=your_openweather_api_key_here

# ── ExchangeRate.host ─────────────────────────────────────────────────────────
EXCHANGERATE_API_KEY=your_exchangerate_api_key_here   # free tier doesn't need one

# ── App Settings ──────────────────────────────────────────────────────────────
MEMORY_WINDOW=20          # max messages before summarisation kicks in
SUMMARY_KEEP=6            # messages kept verbatim after summarisation
