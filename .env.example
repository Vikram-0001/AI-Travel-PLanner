# ── LLM ──────────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-70b-8192         # or mixtral-8x7b-32768

# ── Serp API (Flights & Hotels) ───────────────────────────────────────────────
SERP_API_KEY="your_serp_api_key_here"

# ── OpenWeatherMap ────────────────────────────────────────────────────────────
OPENWEATHER_API_KEY="your_openweather_api_key_here"

# ── ExchangeRate.host ─────────────────────────────────────────────────────────
EXCHANGERATE_API_KEY=your_exchangerate_api_key_here   # free tier doesn't need one

# ── App Settings ──────────────────────────────────────────────────────────────
MEMORY_WINDOW=20          # max messages before summarisation kicks in
SUMMARY_KEEP=6            # messages kept verbatim after summarisation
